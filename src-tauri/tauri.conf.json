{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Power Paste",
  "version": "0.2.9",
  "identifier": "com.yulei.powerpaste",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node scripts/tauri-dev-server.mjs",
    "beforeBuildCommand": "pnpm build"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwN0RGOTQ1MUNDRTJFMTIKUldRU0xzNGNSZmw5NEdrZDJRNmpIZVBGZHVNejdDSFFyVGFsNXJ1bjNpU252TEF5QlV2Z0RqTUoK",
      "endpoints": [
        "https://github.com/iFence/power-paste/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Power Paste",
        "width": 360,
        "height": 760,
        "minWidth": 360,
        "minHeight": 760,
        "decorations": false,
        "transparent": true,
        "devtools": false,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "targets": "all",
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"]
      },
      "wix": {
        "language": ["zh-CN"]
      }
    }
  }
}
